# Supabase — client config for the Fighter's OS app (M1+).
# The anon/publishable key is PUBLIC-SAFE by design: it's the client key, and
# Row-Level Security is what actually protects data. NEVER put the service-role
# key here or anywhere client-side. Copy this file to `.env.local` (gitignored)
# and fill in real values for local dev; set the same vars in Cloudflare Pages
# per-environment for deploys.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Dev-only password login (localhost + agent browser testing) ──────────────
# DEV-ONLY: read only when import.meta.env.DEV is true, so `vite build` strips
# the sign-in path entirely. DO NOT set these in Cloudflare Pages / production.
# Create a password user in Supabase (Auth → Users → Add user → Create new user,
# with "Auto Confirm User" checked), then put its email + password here in your
# gitignored .env.local. A burner email is fine — no email is ever sent.
VITE_DEV_EMAIL=dev@example.com
VITE_DEV_PASSWORD=
# Set to "true" for zero-click auto-login (handy for agent browser testing).
VITE_DEV_AUTOLOGIN=false
